<% content_for :title, "Admin — Posts" %>

<main class="admin">
  <header class="admin__header">
    <h1>Posts</h1>
    <p class="admin__notice"><%= notice if notice.present? %></p>
  </header>

  <table class="admin__table">
    <thead>
      <tr>
        <th>Body</th>
        <th>Reports</th>
        <th>Posted</th>
        <th>Expires</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr class="admin__row<%= ' admin__row--hidden' if post.hidden_at? %>">
          <td class="admin__body"><%= post.body %></td>
          <td><%= post.reports_count %></td>
          <td><%= post.posted_at.to_fs(:short) %></td>
          <td><%= post.expires_at.to_fs(:short) %></td>
          <td>
            <% if post.hidden_at? %>
              Hidden <%= time_ago_in_words(post.hidden_at) %> ago
            <% elsif post.reports_count >= Post::AUTO_HIDE_THRESHOLD %>
              Auto-hidden (reports)
            <% else %>
              Live
            <% end %>
          </td>
          <td>
            <% unless post.hidden_at? %>
              <%= button_to "Hide", admin_post_path(post), method: :delete, class: "admin__hide",
                            data: { turbo_confirm: "Hide this post?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</main>
