<div class="rounded-2xl border border-white/8 bg-[#252525] p-5 shadow-[0_18px_50px_rgba(0,0,0,0.40)]">
  <div class="flex items-center justify-between gap-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">Posting as</p>
      <p class="mt-2 text-lg font-semibold text-slate-100"><%= identity.icon %> <%= identity.pseudonym %></p>
    </div>
    <p class="rounded-full bg-white/8 px-3 py-1 text-xs font-medium text-slate-400">1 note / minute</p>
  </div>

  <% if status_message.present? %>
    <p class="mt-4 rounded-2xl bg-emerald-900/40 px-4 py-3 text-sm font-medium text-emerald-300"><%= status_message %></p>
  <% end %>

  <% if post.errors.any? %>
    <div class="mt-4 rounded-2xl bg-red-900/40 px-4 py-3 text-sm text-red-300">
      <%= post.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with model: post, url: posts_path, class: "mt-4 space-y-3", data: { controller: "composer", composer_limit_value: Post::MAX_BODY_LENGTH } do |form| %>
    <div class="relative">
      <%= form.text_area :body,
            rows: 5,
            maxlength: Post::MAX_BODY_LENGTH,
            placeholder: "Write something small that belongs on #{city.name}'s wall...",
            class: "whiteboard-input min-h-36 w-full rounded-[1.5rem] border border-white/10 bg-white/5 px-4 py-4 pr-16 text-base leading-7 text-slate-100 shadow-inner outline-none transition focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/20 placeholder:text-slate-500",
            data: { action: "input->composer#updateCounter", composer_target: "input" } %>
      <div class="pointer-events-none absolute bottom-4 right-4 rounded-full bg-slate-800/80 px-3 py-1 text-xs font-semibold text-slate-400 shadow-sm">
        <span data-composer-target="counter"><%= Post::MAX_BODY_LENGTH %></span>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3">
      <p class="text-xs leading-5 text-slate-400">
        Text only. Exact repeats are blocked. Notes fade away after two days.
      </p>
      <%= form.submit "Chalk it up", class: "inline-flex shrink-0 items-center rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white/20" %>
    </div>
  <% end %>
</div>
